DJANGO_ENV=local
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-bytes-long
JWT_SIGNING_KEY=change-me-to-a-random-jwt-signing-key-at-least-32-bytes-long
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=it_inventory
POSTGRES_USER=it_user
POSTGRES_PASSWORD=it_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_PORT=8000LOGIN_THROTTLE_RATE=5/5m
AUTH_COOKIE_REQUIRE_ORIGIN=false
AUTH_COOKIE_ALLOWED_ORIGINS=http://localhost:5173